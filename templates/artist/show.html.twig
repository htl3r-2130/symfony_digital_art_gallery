{% extends 'base.html.twig' %}

{% block title %}{{ artist.firstName }} {{ artist.lastName }}{% endblock %}

{% block body %}
<div class="page-content">

    <a href="{{ path('artist_index') }}" class="back-link">← Artists</a>

    <div class="artist-header">
        <div class="artist-avatar-lg">
            {{ artist.firstName|slice(0,1) }}{{ artist.lastName|slice(0,1) }}
        </div>
        <div class="artist-meta">
            <h1 class="artist-name">{{ artist.firstName }} {{ artist.lastName }}</h1>
            <span class="artist-born">b. {{ artist.birthDate|date('Y') }}</span>
        </div>
    </div>

    <div class="section-label-row">
        <span class="section-label">Works</span>
        <span class="section-count">{{ artist.artworks|length }}</span>
    </div>

    {% if artist.artworks is empty %}
        <div class="empty-state">
            <p>No artworks yet.</p>
        </div>
    {% else %}
        <div class="artwork-grid">
            {% for artwork in artist.artworks %}
                <a href="{{ path('artwork_show', { id: artwork.id }) }}" class="artwork-card">
                    <div class="artwork-card-image">
                        {% if artwork.imagePath %}
                            <img src="{{ artwork.imagePath }}" alt="{{ artwork.title }}">
                        {% endif %}
                    </div>
                    <div class="artwork-card-body">
                        <span class="artwork-card-title">{{ artwork.title }}</span>
                        <span class="artwork-card-desc">{{ artwork.description|slice(0,60) }}{% if artwork.description|length > 60 %}…{% endif %}</span>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}

{% block styles %}
<style>
    .page-content {
        max-width: 860px;
        margin: 0 auto;
        padding: 2.5rem 2rem;
    }

    .back-link {
        display: inline-block;
        font-size: 0.82rem;
        color: var(--text-secondary);
        text-decoration: none;
        margin-bottom: 2rem;
        transition: color 0.2s;
    }

    .back-link:hover { color: var(--text); }

    /* Artist header */
    .artist-header {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        margin-bottom: 2.5rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border);
    }

    .artist-avatar-lg {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        font-weight: 500;
        color: var(--text-secondary);
        flex-shrink: 0;
    }

    .artist-meta {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .artist-name {
        font-size: 1.6rem;
        font-weight: 600;
        letter-spacing: -0.025em;
    }

    .artist-born {
        font-size: 0.8rem;
        color: var(--text-tertiary);
    }

    /* Section label */
    .section-label-row {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 1rem;
    }

    .section-label {
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .section-count {
        font-size: 0.72rem;
        font-weight: 500;
        color: var(--text-tertiary);
        background: var(--bg-secondary);
        border-radius: 980px;
        padding: 0.1rem 0.5rem;
    }

    /* Artwork grid */
    .artwork-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1px;
        background: var(--border);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--border);
    }

    .artwork-card {
        display: flex;
        flex-direction: column;
        background: var(--bg);
        text-decoration: none;
        color: var(--text);
        transition: background 0.15s;
    }

    .artwork-card:hover { background: var(--bg-secondary); }

    .artwork-card-image {
        aspect-ratio: 4/3;
        background: var(--bg-secondary);
        overflow: hidden;
    }

    .artwork-card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.3s ease;
    }

    .artwork-card:hover .artwork-card-image img {
        transform: scale(1.03);
    }

    .artwork-card-body {
        padding: 0.85rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
    }

    .artwork-card-title {
        font-size: 0.85rem;
        font-weight: 500;
        letter-spacing: -0.01em;
    }

    .artwork-card-desc {
        font-size: 0.75rem;
        color: var(--text-tertiary);
        line-height: 1.4;
    }

    .empty-state {
        padding: 3rem 2rem;
        text-align: center;
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    @media (max-width: 640px) {
        .artwork-grid { grid-template-columns: repeat(2, 1fr); }
    }
</style>
{% endblock %}