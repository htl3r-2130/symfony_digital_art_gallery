{% extends 'base.html.twig' %}

{% block title %}Virtual Tours{% endblock %}

{% block body %}
<div class="page-content">

    <div class="page-header">
        <h1 class="page-title">Virtual Tours</h1>
    </div>

    {% if tours is empty %}
        <div class="empty-state">
            <p>No tours available.</p>
        </div>
    {% else %}
        <div class="tour-list">
            {% for tour in tours %}
                <a href="{{ path('tour_show', { id: tour.id }) }}" class="tour-card">
                    <div class="tour-card-body">
                        <span class="tour-title">{{ tour.title }}</span>
                        <span class="tour-desc">{{ tour.description|slice(0, 100) }}{% if tour.description|length > 100 %}…{% endif %}</span>
                    </div>
                    <span class="tour-cta">Enter Tour →</span>
                </a>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}

{% block styles %}
<style>
    .page-content {
        max-width: 860px;
        margin: 0 auto;
        padding: 3rem 2rem;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 2rem;
        font-weight: 600;
        letter-spacing: -0.03em;
    }

    .tour-list {
        display: flex;
        flex-direction: column;
        gap: 1px;
        background: var(--border);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--border);
    }

    .tour-card {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: 1.25rem 1.5rem;
        background: var(--bg);
        text-decoration: none;
        color: var(--text);
        transition: background 0.15s;
    }

    .tour-card:hover { background: var(--bg-secondary); }

    .tour-card-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .tour-title {
        font-size: 0.95rem;
        font-weight: 500;
        letter-spacing: -0.01em;
    }

    .tour-desc {
        font-size: 0.8rem;
        color: var(--text-secondary);
        line-height: 1.5;
    }

    .tour-cta {
        font-size: 0.78rem;
        font-weight: 500;
        color: var(--text-secondary);
        white-space: nowrap;
        transition: color 0.15s, transform 0.2s;
        display: inline-block;
    }

    .tour-card:hover .tour-cta {
        color: var(--text);
        transform: translateX(3px);
    }

    .empty-state {
        padding: 4rem 2rem;
        text-align: center;
        color: var(--text-secondary);
        font-size: 0.9rem;
    }
</style>
{% endblock %}