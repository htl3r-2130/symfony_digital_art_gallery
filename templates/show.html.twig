{% extends 'base.html.twig' %}

{% block title %}{{ artwork.title }}{% endblock %}

{% block body %}
    <main>
        <article>
            <h1>{{ artwork.title }}</h1>
            <img src="{{ artwork.imagePath }}" alt="{{ artwork.title }}">
            <p>{{ artwork.description }}</p>
            <p>Created: {{ artwork.creationDate|date('Y') }}</p>
            <p>Artist: {{ artwork.artist.firstName }} {{ artwork.artist.lastName }}</p>
        </article>

        <nav>
            <a href="{{ path('artwork_index') }}">← Back to Gallery</a>
        </nav>
    </main>
{% endblock %}