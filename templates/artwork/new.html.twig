{% extends 'base.html.twig' %}

{% block title %}Add New Artwork{% endblock %}

{% block body %}
<div class="page-content">

    <a href="{{ path('artwork_index') }}" class="back-link">← Gallery</a>

    <div class="form-card">
        <h1 class="form-title">Add Artwork</h1>

        {{ form_start(form, { attr: { class: 'art-form' } }) }}
            {{ form_row(form.title) }}
            {{ form_row(form.description) }}
            {{ form_row(form.imagePath) }}
            {{ form_row(form.creationDate) }}
            {{ form_row(form.artist) }}
            <div class="form-footer">
                {{ form_row(form.submit) }}
            </div>
        {{ form_end(form) }}
    </div>

</div>
{% endblock %}

{% block styles %}
<style>
    {{ block('form_styles') }}
</style>
{% endblock %}

{% block form_styles %}
    .page-content {
        max-width: 560px;
        margin: 0 auto;
        padding: 2.5rem 2rem;
    }

    .back-link {
        display: inline-block;
        font-size: 0.82rem;
        color: var(--text-secondary);
        text-decoration: none;
        margin-bottom: 2rem;
        transition: color 0.2s;
    }

    .back-link:hover { color: var(--text); }

    .form-card {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 2rem;
    }

    .form-title {
        font-size: 1.4rem;
        font-weight: 600;
        letter-spacing: -0.025em;
        margin-bottom: 1.75rem;
    }

    .art-form .form-group,
    .art-form div {
        margin-bottom: 1.1rem;
    }

    .art-form label {
        display: block;
        font-size: 0.78rem;
        font-weight: 500;
        color: var(--text-secondary);
        margin-bottom: 0.35rem;
    }

    .art-form input,
    .art-form textarea,
    .art-form select {
        width: 100%;
        padding: 0.6rem 0.85rem;
        font-size: 0.88rem;
        font-family: var(--font);
        color: var(--text);
        background: var(--bg-secondary);
        border: 1px solid transparent;
        border-radius: 10px;
        outline: none;
        transition: border-color 0.2s, background 0.2s;
    }

    .art-form input:focus,
    .art-form textarea:focus,
    .art-form select:focus {
        background: var(--bg);
        border-color: rgba(0,0,0,0.2);
    }

    .art-form textarea {
        resize: vertical;
        min-height: 90px;
    }

    .form-footer {
        margin-top: 1.75rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--border);
    }

    .art-form button[type="submit"],
    .art-form input[type="submit"] {
        width: auto;
        padding: 0.6rem 1.5rem;
        background: var(--text);
        color: #fff;
        font-size: 0.85rem;
        font-weight: 500;
        border: none;
        border-radius: 980px;
        cursor: pointer;
        transition: opacity 0.2s;
    }

    .art-form button[type="submit"]:hover,
    .art-form input[type="submit"]:hover {
        opacity: 0.82;
    }
{% endblock %}