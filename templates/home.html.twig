{% extends 'base.html.twig' %}

{% block title %}Gallery Am Fluss{% endblock %}

{% block body %}
<div class="page-content home">

    <section class="hero">
        <div class="hero-inner">
            <img src="/images/Gallery-am-Fluss.svg" alt="Gallery Am Fluss" class="hero-logo">
            <p class="hero-sub">Contemporary art in the heart of Vienna.</p>
            <div class="hero-actions">
                <a href="{{ path('artwork_index') }}" class="btn-primary">Explore Gallery</a>
                <a href="{{ path('tour_index') }}" class="btn-secondary">Virtual Tour</a>
            </div>
        </div>
    </section>

</div>
{% endblock %}

{% block styles %}
<style>
    .home {
        display: flex;
        flex-direction: column;
    }

    /* ─── HERO ────────────────────────────────────── */
    .hero {
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 7rem 2rem 5rem;
        background: var(--bg);
    }

    .hero-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        max-width: 640px;
    }

    .hero-logo {
        width: clamp(200px, 28vw, 380px);
        height: auto;
    }

    .hero-sub {
        font-size: 1.1rem;
        font-weight: 300;
        color: var(--text-secondary);
        letter-spacing: -0.01em;
        line-height: 1.5;
    }

    .hero-actions {
        display: flex;
        gap: 0.75rem;
        margin-top: 0.5rem;
    }

    .btn-primary {
        display: inline-flex;
        align-items: center;
        padding: 0.6rem 1.4rem;
        background: var(--text);
        color: #fff;
        font-size: 0.8rem;
        font-weight: 500;
        border-radius: 980px;
        text-decoration: none;
        transition: opacity 0.2s ease;
    }

    .btn-primary:hover { opacity: 0.82; }

    .btn-secondary {
        display: inline-flex;
        align-items: center;
        padding: 0.6rem 1.4rem;
        background: var(--bg-secondary);
        color: var(--text);
        font-size: 0.8rem;
        font-weight: 500;
        border-radius: 980px;
        text-decoration: none;
        transition: background 0.2s ease;
    }

    .btn-secondary:hover { background: #E5E5EA; }

    /* ─── RESPONSIVE ──────────────────────────────── */
    @media (max-width: 768px) {
        .hero { padding: 4rem 1.5rem 3rem; }
        .hero-actions { flex-direction: column; align-items: center; }
        .card { padding: 1rem 1.25rem; }
        nav { padding: 0 1.25rem; }
        .nav-links { gap: 1.25rem; }
    }
</style>
{% endblock %}